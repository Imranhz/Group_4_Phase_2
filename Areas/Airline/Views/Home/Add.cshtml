@model Group4Flight.Models.FlightViewModel
@{
    ViewData["Title"] = "Add Flight";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">Add New Flight</h4>
            </div>
            <div class="card-body">
                <form asp-action="Add" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Flight Code</label>
                            <input type="text" name="FlightCode" class="form-control" placeholder="e.g. AC101" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Airline</label>
                            <select name="AirlineId" class="form-select" required>
                                <option value="">-- Select Airline --</option>
                                @foreach (var airline in Model.Airlines)
                                {
                                    <option value="@airline.AirlineId">@airline.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">From</label>
                            <input type="text" name="From" class="form-control" placeholder="e.g. Toronto" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">To</label>
                            <input type="text" name="To" class="form-control" placeholder="e.g. Vancouver" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Date</label>
                            <input type="date" name="Date" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Departure Time</label>
                            <input type="time" name="DepartureTime" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Arrival Time</label>
                            <input type="time" name="ArrivalTime" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Cabin Type</label>
                            <select name="CabinType" class="form-select" required>
                                <option value="">-- Select Cabin --</option>
                                @foreach (var cabin in Group4Flight.Models.FlightViewModel.CabinTypes)
                                {
                                    <option value="@cabin">@cabin</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Aircraft Type</label>
                            <select name="AircraftType" class="form-select" required>
                                <option value="">-- Select Aircraft --</option>
                                @foreach (var aircraft in Group4Flight.Models.FlightViewModel.AircraftTypes)
                                {
                                    <option value="@aircraft">@aircraft</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Emission (kg CO₂)</label>
                            <input type="number" name="Emission" class="form-control" placeholder="e.g. 120.5" min="0" step="0.1" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Price ($)</label>
                            <input type="number" name="Price" class="form-control" placeholder="e.g. 299.99" min="0" step="0.01" required />
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-success">Add Flight</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
