@model Group4Flight.Models.Flight
@{
    ViewData["Title"] = "Edit Flight";
    var airlines = (List<Group4Flight.Models.Airline>)(ViewBag.Airlines ?? new List<Group4Flight.Models.Airline>());
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Edit Flight — <span class="badge bg-white text-primary">@Model.FlightCode</span></h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="FlightId" value="@Model.FlightId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Flight Code</label>
                            <input type="text" name="FlightCode" value="@Model.FlightCode" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Airline</label>
                            <select name="AirlineId" class="form-select" required>
                                <option value="">-- Select Airline --</option>
                                @foreach (var airline in airlines)
                                {
                                    <option value="@airline.AirlineId" selected="@(Model.AirlineId == airline.AirlineId ? "selected" : null)">
                                        @airline.Name
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">From</label>
                            <input type="text" name="From" value="@Model.From" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">To</label>
                            <input type="text" name="To" value="@Model.To" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Date</label>
                            <input type="date" name="Date" value="@Model.Date.ToString("yyyy-MM-dd")" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Departure Time</label>
                            <input type="time" name="DepartureTime" value="@Model.DepartureTime.ToString(@"hh\:mm")" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Arrival Time</label>
                            <input type="time" name="ArrivalTime" value="@Model.ArrivalTime.ToString(@"hh\:mm")" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Cabin Type</label>
                            <select name="CabinType" class="form-select" required>
                                <option value="">-- Select Cabin --</option>
                                @foreach (var cabin in Group4Flight.Models.FlightViewModel.CabinTypes)
                                {
                                    <option value="@cabin" selected="@(Model.CabinType == cabin ? "selected" : null)">@cabin</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Aircraft Type</label>
                            <select name="AircraftType" class="form-select" required>
                                <option value="">-- Select Aircraft --</option>
                                @foreach (var aircraft in Group4Flight.Models.FlightViewModel.AircraftTypes)
                                {
                                    <option value="@aircraft" selected="@(Model.AircraftType == aircraft ? "selected" : null)">@aircraft</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Emission (kg CO₂)</label>
                            <input type="number" name="Emission" value="@Model.Emission" class="form-control" min="0" step="0.1" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Price ($)</label>
                            <input type="number" name="Price" value="@Model.Price" class="form-control" min="0" step="0.01" required />
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
